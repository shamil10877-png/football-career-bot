@dp.message(Command("house"))
async def house(message: Message):
    p = load(message.from_user.id)

    if not p:
        return await message.answer("❌ Создай карьеру.")

    if "house" not in p:
        p["house"] = "Нет"

    prices = {
        "Квартира": 300000,
        "Дом": 1200000,
        "Вилла": 5000000
    }

    if p["house"] == "Нет":
        for name, cost in prices.items():
            if p["money"] >= cost:
                p["money"] -= cost
                p["house"] = name
                save(message.from_user.id, p)
                return await message.answer(f"🏠 Ты купил: {name}")

        return await message.answer("💸 Денег пока недостаточно.")

    await message.answer(f"🏠 Твой дом: {p['house']}")


