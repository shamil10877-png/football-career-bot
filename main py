async def match(message: Message):
    p = load(message.from_user.id)

    if not p:
        await message.answer("❌ Сначала создай карьеру.")
        return

    if p["fitness"] < 15:
        await message.answer("😴 Ты слишком устал. Используй /rest")
        return

    # Чем выше рейтинг — тем лучше статистика
    goals = random.randint(0, max(1, p["rating"] // 30))
    assists = random.randint(0, max(1, p["rating"] // 40))

    mvp = random.randint(1, 100) <= p["rating"] - 40

    p["matches"] += 1
    p["goals"] += goals
    p["assists"] += assists

    if mvp:
        p["mvps"] += 1

    gain = goals * 0.40 + assists * 0.25
    if mvp:
        gain += 0.50

    p["rating"] = round(min(99, p["rating"] + gain), 1)

    reward = (
        goals * 15000 +
        assists * 9000 +
        (25000 if mvp else 0)
    )

    p["money"] += reward

    p["market_value"] = int(p["rating"] * 120000)

    p["fitness"] = max(0, p["fitness"] - random.randint(10, 20))

    p["followers"] += random.randint(100, 600)

